{
  "rules": {
    "library_status": {
      ".read": true, 
      ".write": true 
    },
    "staff_presence": {
      ".read": true,
      ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || auth.token.email.matches(/.*@gmail.com/))"
    },
    "active_reservations": {
      ".read": true,
      ".write": "auth != null"
    },
    "announcements": {
      ".read": true,
      ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || auth.token.email.matches(/.*@gmail.com/))" 
    }
  }
}
